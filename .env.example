# Lira V2 — Environment Variables

# LLM Provider
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b
OLLAMA_MEMORY_MODEL=qwen3:32b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (fallback / cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MEMORY_MODEL=gpt-4.1-nano

# PostgreSQL (structured memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lira
POSTGRES_PASSWORD=lira_password
POSTGRES_DB=lira_v2

# Qdrant (vector memory)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Whisper STT
WHISPER_BASE_URL=http://localhost:19002

# Kokoro TTS
KOKORO_BASE_URL=http://localhost:19008
KOKORO_VOICE=bf_isabella
KOKORO_SPEED=1.0
KOKORO_PITCH=0
KOKORO_VOLUME=0

# XTTSv2 (optional, voice cloning)
XTTS_BASE_URL=

# ComfyUI (image/video generation)
COMFYUI_BASE_URL=http://localhost:8188

# LiveKit (realtime communication)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Feature Flags
ENABLE_VOICE=true
ENABLE_AVATAR=false
ENABLE_VISION=false
ENABLE_COMPANION_LOOP=false
ENABLE_INTERNAL_THOUGHTS=false
DEBUG_MODE=false
SAFE_MODE=false

# Logging
LOG_LEVEL=info
LOG_SUBSYSTEMS=orchestrator,memory,model-router,audio,emotion,vision
